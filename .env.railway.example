# ============================================================
# KAVACH AI — Railway Environment Variables Reference
# Copy these into the Railway dashboard → Variables tab.
# DO NOT commit a filled-in copy of this file.
# ============================================================

# ===== REQUIRED =====
SPRING_PROFILES_ACTIVE=dev
SPRING_DATASOURCE_URL=jdbc:postgresql://<neon-host>/<db>?sslmode=require
SPRING_DATASOURCE_USERNAME=<neon-user>
SPRING_DATASOURCE_PASSWORD=<neon-password>
JWT_SECRET=<minimum-32-chars-random-string>
CORS_ORIGINS=https://kavach-core-web-appss.vercel.app,http://localhost:3000

# ===== PAYMENTS (set to dummy until Razorpay is wired up) =====
RAZORPAY_KEY_ID=dummy
RAZORPAY_KEY_SECRET=dummy
RAZORPAY_WEBHOOK_SECRET=dummy

# ===== SCREENSHOTS (set to dummy until R2 is wired up) =====
R2_ACCOUNT_ID=dummy
R2_ACCESS_KEY_ID=dummy
R2_SECRET_ACCESS_KEY=dummy
R2_BUCKET_NAME=dummy

# ===== AI (optional — falls back to mock response if omitted) =====
GEMINI_API_KEY=dummy
