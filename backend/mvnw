#!/bin/sh
# ────────────────────────────────────────────────────────────────────────────
# Maven Wrapper Script
# ────────────────────────────────────────────────────────────────────────────
# Licensed to the Apache Software Foundation (ASF) under one or more
# contributor license agreements. See the NOTICE file distributed with this
# work for additional information regarding copyright ownership.

if [ -z "$JAVA_HOME" ]; then
  javaExecutable="`which java`"
  if [ -n "$javaExecutable" ] && ! [ "`ls -l $javaExecutable | grep -c ' -> '`" -gt 0 ]; then
    JAVA_HOME="`dirname $javaExecutable`/.."
  fi
fi

# Set MAVEN_PROJECTBASEDIR if not already set
if [ -z "$MAVEN_PROJECTBASEDIR" ]; then
  # Get the directory where this script is located
  SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
  MAVEN_PROJECTBASEDIR="$SCRIPT_DIR"
fi

MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

# Download wrapper if needed
if [ ! -f "$MAVEN_WRAPPER_JAR" ]; then
  wrapperUrl=$(grep "wrapperUrl" "$WRAPPER_PROPERTIES" | cut -d= -f2-)
  echo "Downloading maven wrapper from $wrapperUrl"
  if command -v curl > /dev/null; then
    curl -o "$MAVEN_WRAPPER_JAR" "$wrapperUrl" -f
  elif command -v wget > /dev/null; then
    wget "$wrapperUrl" -O "$MAVEN_WRAPPER_JAR"
  fi
fi

# Use Maven Wrapper main class (avoids needing a Main-Class manifest entry)
# Pass the multiModuleProjectDirectory property directly to Java
# Note: We use exec with proper argument handling for paths with spaces
if [ -n "$JAVA_OPTS" ] && [ -n "$MAVEN_OPTS" ]; then
  exec "$JAVA_HOME/bin/java" $JAVA_OPTS $MAVEN_OPTS -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" -classpath "$MAVEN_WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
elif [ -n "$JAVA_OPTS" ]; then
  exec "$JAVA_HOME/bin/java" $JAVA_OPTS -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" -classpath "$MAVEN_WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
elif [ -n "$MAVEN_OPTS" ]; then
  exec "$JAVA_HOME/bin/java" $MAVEN_OPTS -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" -classpath "$MAVEN_WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
else
  exec "$JAVA_HOME/bin/java" -Dmaven.multiModuleProjectDirectory="$MAVEN_PROJECTBASEDIR" -classpath "$MAVEN_WRAPPER_JAR" org.apache.maven.wrapper.MavenWrapperMain "$@"
fi
