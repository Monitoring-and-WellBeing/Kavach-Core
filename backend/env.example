# ═══════════════════════════════════════════════════════════════
# KAVACH AI — Backend Environment Variables
# Copy to .env and fill in your values before starting the server.
# All variables without defaults MUST be set in production.
# ═══════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/kavach_db
SPRING_DATASOURCE_USERNAME=kavach
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_strong_password

# ── JWT (HS256 — MUST be >= 256 bits / 32 characters) ───────────
JWT_SECRET=CHANGE_ME_minimum_32_char_random_string_here_use_openssl_rand
# Access token: 15 min (ms). Refresh token: 7 days (ms).
JWT_ACCESS_EXPIRY=900000
JWT_REFRESH_EXPIRY=604800000

# ── Server ───────────────────────────────────────────────────────
PORT=8080

# ── CORS (comma-separated list of allowed origins) ───────────────
CORS_ORIGINS=https://your-production-domain.com

# ── Gemini AI (leave blank to disable AI features) ───────────────
GEMINI_API_KEY=

# ── Cloudflare R2 Storage (for screenshots) ──────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=kavach-screenshots

# ── Razorpay Payments ─────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
