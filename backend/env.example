# ═══════════════════════════════════════════════════════════════
# KAVACH AI — Backend Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/kavach_db
SPRING_DATASOURCE_USERNAME=kavach
SPRING_DATASOURCE_PASSWORD=kavach123

# JWT (must be at least 256 bits for HS256)
JWT_SECRET=kavach-super-secret-key-change-in-production-2024-must-be-at-least-256-bits
JWT_EXPIRATION=86400000

# Server
PORT=8080

# Optional: Override API URL for Docker
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/kavach_db
