{
  "name": "desktop-agent",
  "version": "1.2.4",
  "description": "KAVACH AI Desktop Monitoring Agent",
  "author": "KAVACH AI",
  "repository": {
    "type": "git",
    "url": "https://github.com/Monitoring-and-WellBeing/Kavach-Core"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "write-config": "node scripts/write-build-config.cjs",
    "build": "tsc",
    "build:full": "tsc && electron-builder",
    "pack": "electron-builder",
    "dist:win": "node scripts/write-build-config.cjs && tsc && electron-builder --win",
    "dist:mac": "node scripts/write-build-config.cjs && tsc && electron-builder --mac",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "tsc --noEmit",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@kavach/shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3"
  }
}
