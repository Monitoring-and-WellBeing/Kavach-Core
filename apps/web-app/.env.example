# ============================================================
# KAVACH AI — Web App Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# All NEXT_PUBLIC_* variables are inlined at build time and
# must be set in the Vercel dashboard under Project -> Settings -> Environment Variables.
# ============================================================

# -- Required -----------------------------------------------------------------

# Base URL of the Kavach backend API.
# Example (production): https://api.kavach.ai
# Example (local):      http://localhost:8080
NEXT_PUBLIC_API_URL=http://localhost:8080

# -- Optional -----------------------------------------------------------------

# Set to "true" to show demo credential hints on the login page.
# Never set to "true" in production.
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false

# Set to "standalone" to enable Next.js standalone output mode (used for Docker deploys).
# Leave empty for Vercel deployments.
NEXT_OUTPUT=
