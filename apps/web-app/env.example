# ═══════════════════════════════════════════════════════════════
# KAVACH AI — Web App Environment Variables
# Copy to .env.local and fill in your values.
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
# ═══════════════════════════════════════════════════════════════

# ── Backend API base URL (NO trailing slash, NO /api/v1 suffix) ──
# The axios client in src/lib/axios.ts appends /api/v1 automatically.
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Demo credentials quick-fill (set to "true" in dev/staging only) ─
# When "true", the login page shows pre-filled demo account buttons.
# NEVER set this to "true" in production.
NEXT_PUBLIC_SHOW_DEMO_CREDENTIALS=false

# ── App branding ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=KAVACH AI

# ── Next.js build mode (set to "standalone" for Docker) ──────────
# NEXT_OUTPUT=standalone
