# ═══════════════════════════════════════════════════════════════
# KAVACH AI — Mobile App Environment Variables (Expo / React Native)
# These are read by Expo at build-time via app.config.js / app.json
# Copy to .env and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ── Backend API base URL (HTTPS in production) ───────────────────
EXPO_PUBLIC_API_URL=https://api.your-production-domain.com/api/v1

# ── Background enforcement poll interval (milliseconds) ──────────
EXPO_PUBLIC_TRACKING_INTERVAL=15000

# ── Debug logging (set to "false" in production builds) ──────────
EXPO_PUBLIC_DEBUG=false
