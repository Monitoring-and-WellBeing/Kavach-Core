{
  "name": "kavach-student-mobile",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "dev-client": "expo start --dev-client",
    "prebuild": "expo prebuild --clean",
    "prebuild:android": "expo prebuild --clean --platform android",
    "type-check": "tsc --noEmit",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --watchAll=false --coverage",
    "build:dev": "eas build --platform android --profile development",
    "build:android": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "axios": "^1.7.2",
    "expo": "~51.0.0",
    "expo-dev-client": "~3.3.12",
    "expo-background-fetch": "~12.0.1",
    "expo-build-properties": "~0.12.3",
    "expo-haptics": "~13.0.1",
    "expo-keep-awake": "~13.0.2",
    "expo-location": "~17.0.1",
    "expo-notifications": "~0.28.3",
    "expo-status-bar": "~1.12.1",
    "expo-task-manager": "~11.8.2",
    "react": "18.2.0",
    "react-native": "0.74.1",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "victory-native": "^41.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@types/jest": "^29.5.12",
    "@types/react": "~18.2.79",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.3",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.3.3"
  }
