{
  "name": "kavach-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:web": "pnpm --filter web-app dev",
    "dev:desktop": "pnpm --filter desktop-agent dev",
    "dev:backend": "cd backend && ./mvnw spring-boot:run"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@9.0.0"
}
