{
  "name": "kavach-ai",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:web": "pnpm --filter web-app dev",
    "dev:desktop": "pnpm --filter desktop-agent dev",
    "dev:backend": "mvn -f backend/pom.xml spring-boot:run"
  },
  "devDependencies": {
    "@jest/test-sequencer": "29.7.0",
    "turbo": "^1.13.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=18.17.0",
    "pnpm": ">=10.0.0"
  }
}
